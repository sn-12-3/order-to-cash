# IBM MQ Configuration
MQ_HOST=localhost
MQ_PORT=1414
MQ_QUEUE_MANAGER=QM1
MQ_CHANNEL=DEV.APP.SVRCONN
MQ_QUEUE_NAME=customer_purchase_orders
MQ_USER=app
MQ_PASSWORD=passw0rd

# SAP Configuration
SAP_BASE_URL=http://localhost:3001
SAP_SALES_ORDER_ENDPOINT=/sap/api/sales-order

# Kafka Configuration
KAFKA_BROKERS=localhost:9093
KAFKA_CLIENT_ID=o2c-integration
KAFKA_SUCCESS_TOPIC=submitted_orders
KAFKA_FAILED_TOPIC=failed_orders

# Application Configuration
POLL_INTERVAL_MS=5000
MAX_RETRIES=3
RETRY_DELAY_MS=2000
LOG_LEVEL=info